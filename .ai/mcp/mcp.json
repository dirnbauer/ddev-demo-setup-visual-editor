{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "agentation": {
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ]
    },
    "typo3": {
      "command": "ddev",
      "args": [
        "exec",
        "php",
        "vendor/bin/typo3",
        "mcp:server",
        "--user",
        "admin"
      ],
      "cwd": "/Users/dirnbauer/projects/ddev-demo-setup-visual-editor"
    }
  }
}
