{
    "name": "typo3/cms-base-distribution",
    "description": "TYPO3 CMS Base Distribution",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "php-http/discovery": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "use-github-api": false,
        "preferred-install": {
            "typo3/*": "source",
            "marekskopal/typo3-mcp-server": "source",
            "t3g/blog": "source",
            "webconsulting/*": "source",
            "*": "source"
        },
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/typo3-agentation.git"
        },
        {
            "name": "records-list-examples",
            "type": "vcs",
            "url": "https://github.com/dirnbauer/typo3-records-list-examples.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/desiderio.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/marekskopal/typo3-mcp-server.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/blog.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/typo3-records-list-types.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/visual-editor-news-addon.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/shadcn2fluid-templates.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/typo3-x402-paywall.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/typo3-capability-manifest.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/t3x-nr-llm.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/t3x-nr-vault.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/t3x-cowriter.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/t3x-nr-mcp-agent.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/dirnbauer/workos.git",
            "no-api": true
        }
    ],
    "extra": {
        "composer-exit-on-patch-failure": true,
        "patches": {
            "friendsoftypo3/content-blocks": {
                "Create parent reference columns for collection indexes": "patches/friendsoftypo3/content-blocks/0001-create-parent-uid-column-for-collection-index.patch"
            },
            "marekskopal/typo3-mcp-server": {
                "Support resource-specific OAuth protected resource metadata": "patches/marekskopal/typo3-mcp-server/0001-support-resource-specific-oauth-metadata.patch",
                "Support legacy tagged MCP tool metadata": "patches/marekskopal/typo3-mcp-server/0002-support-legacy-tagged-tool-metadata.patch"
            },
            "netresearch/nr-mcp-agent": {
                "Normalize MCP tool schemas and remove active chat list inset border": "patches/netresearch/nr-mcp-agent/0001-normalize-tool-schemas-and-chat-active-state.patch"
            },
            "typo3/cms-backend": {
                "PageTreeRepository: skip missing mount point records (forge bug, search filter null deref)": "patches/typo3/cms-backend/0001-pagetreerepository-skip-missing-mountpoint-records.patch"
            },
            "webconsulting/typo3-x402-paywall": {
                "Use current MCP SDK result types": "patches/webconsulting/typo3-x402-paywall/0001-use-current-mcp-sdk-result-types.patch"
            }
        }
    },
    "require": {
        "apache-solr-for-typo3/solr": "^14.0@alpha",
        "cweagans/composer-patches": "^1.7",
        "dirnbauer/adminpanel-defaults": "dev-main",
        "dirnbauer/visual-editor-news-addon": "dev-main",
        "friendsoftypo3/tt-address": "^10.0",
        "friendsoftypo3/visual-editor": "^1.1",
        "georgringer/context-edit-records": "^1.0",
        "georgringer/news": "^14.0",
        "georgringer/numbered-pagination": "^2.2",
        "marekskopal/typo3-mcp-docs": "^1.1",
        "marekskopal/typo3-mcp-server": "^0.9",
        "netresearch/nr-llm": "dev-main as 0.7.0",
        "netresearch/nr-mcp-agent": "dev-main",
        "netresearch/nr-vault": "dev-main as 0.5.0",
        "netresearch/t3-cowriter": "dev-main as 3.1.1",
        "studiomitte/solr-numbered-pagination": "dev-main",
        "supseven/inline-page-module": "^4.0",
        "t3g/blog": "dev-master",
        "typo3/class-alias-loader": "2.0.1 as 1.99.0",
        "typo3/cms-adminpanel": "^14.3",
        "typo3/cms-backend": "^14.3",
        "typo3/cms-belog": "^14.3",
        "typo3/cms-beuser": "^14.3",
        "typo3/cms-core": "^14.3",
        "typo3/cms-dashboard": "^14.3",
        "typo3/cms-extbase": "^14.3",
        "typo3/cms-extensionmanager": "^14.3",
        "typo3/cms-felogin": "^14.3",
        "typo3/cms-filelist": "^14.3",
        "typo3/cms-fluid": "^14.3",
        "typo3/cms-fluid-styled-content": "^14.3",
        "typo3/cms-form": "^14.3",
        "typo3/cms-frontend": "^14.3",
        "typo3/cms-impexp": "^14.3",
        "typo3/cms-indexed-search": "^14.3",
        "typo3/cms-info": "^14.3",
        "typo3/cms-install": "^14.3",
        "typo3/cms-lowlevel": "^14.3",
        "typo3/cms-reactions": "^14.3",
        "typo3/cms-recycler": "^14.3",
        "typo3/cms-redirects": "^14.3",
        "typo3/cms-rte-ckeditor": "^14.3",
        "typo3/cms-scheduler": "^14.3",
        "typo3/cms-seo": "^14.3",
        "typo3/cms-setup": "^14.3",
        "typo3/cms-styleguide": "^14.3",
        "typo3/cms-sys-note": "^14.3",
        "typo3/cms-tstemplate": "^14.3",
        "typo3/cms-viewpage": "^14.3",
        "typo3/cms-webhooks": "^14.3",
        "typo3/cms-workspaces": "^14.3",
        "typo3/theme-camino": "^14.3",
        "webconsulting/agentation": "dev-main",
        "webconsulting/desiderio": "dev-main",
        "webconsulting/records-list-examples": "dev-main",
        "webconsulting/records-list-types": "dev-main as 1.0.0",
        "webconsulting/typo3-capability-manifest": "dev-main",
        "webconsulting/typo3-x402-paywall": "dev-main",
        "webconsulting/workos-auth": "dev-main"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    }
}
