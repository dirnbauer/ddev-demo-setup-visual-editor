Subject: [PATCH] Normalize MCP tool schemas

OpenAI-compatible tool schemas require array nodes to define `items`. Normalize
schemas recursively before sending them to the chat provider so malformed MCP
server schemas cannot break chat setup.

--- a/Classes/Mcp/McpToolProvider.php
+++ b/Classes/Mcp/McpToolProvider.php
@@ -290,6 +290,8 @@ final class McpToolProvider implements McpToolProviderInterface
             return ['type' => 'object', 'properties' => new stdClass()];
         }
 
+        $schema = $this->normalizeSchemaNode($schema);
+
         if (($schema['type'] ?? null) !== 'object') {
             $schema['type'] = 'object';
         }
@@ -313,4 +315,36 @@ final class McpToolProvider implements McpToolProviderInterface
 
         return $schema;
     }
+
+    /**
+     * @param array<string, mixed> $schema
+     * @return array<string, mixed>
+     */
+    private function normalizeSchemaNode(array $schema): array
+    {
+        if (($schema['type'] ?? null) === 'array' && !isset($schema['items'])) {
+            $schema['items'] = new stdClass();
+        }
+
+        if (isset($schema['properties']) && is_array($schema['properties'])) {
+            foreach ($schema['properties'] as $name => $propertySchema) {
+                if (is_array($propertySchema)) {
+                    /** @var array<string, mixed> $propertySchema */
+                    $schema['properties'][$name] = $this->normalizeSchemaNode($propertySchema);
+                }
+            }
+
+            if ($schema['properties'] === []) {
+                $schema['properties'] = new stdClass();
+            }
+        }
+
+        if (isset($schema['items']) && is_array($schema['items'])) {
+            /** @var array<string, mixed> $itemsSchema */
+            $itemsSchema = $schema['items'];
+            $schema['items'] = $this->normalizeSchemaNode($itemsSchema);
+        }
+
+        return $schema;
+    }
 }
